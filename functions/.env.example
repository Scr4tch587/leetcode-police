# Non-secret Cloud Functions parameters (firebase-functions v2 params API).
# Copy to `.env` (loaded for all projects) or `.env.<projectId>` for one
# project. The secret TWILIO_AUTH_TOKEN is NOT set here — store it in Secret
# Manager via:  firebase functions:secrets:set TWILIO_AUTH_TOKEN

# IANA timezone for the daily cutoff, reminders and summaries.
TIMEZONE=America/Toronto

# Twilio account SID (starts with AC...).
TWILIO_ACCOUNT_SID=

# The Twilio phone number that sends SMS (E.164, e.g. +15195551234).
TWILIO_FROM_NUMBER=

# Set to "false" only when testing the webhook locally without real Twilio.
VALIDATE_TWILIO_SIGNATURE=true
