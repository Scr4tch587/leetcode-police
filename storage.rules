rules_version = '2';

// Storage rules for LeetCode Police.
// Screenshots are written ONLY by the Twilio webhook Cloud Function (admin
// SDK, bypasses rules). Clients may read screenshots that belong to their
// group's submissions, but the simplest safe default is to serve images via
// short-lived signed URLs generated by Functions. We therefore deny all
// direct client access here and rely on signed download URLs stored on the
// submission document.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
