# Firebase web app config — copy to `.env.local` and fill in from the Firebase
# console (Project settings > General > Your apps > SDK setup and configuration)
# or from `firebase apps:sdkconfig web`.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloud Functions region (must match functions/src/config.ts REGION).
VITE_FUNCTIONS_REGION=northamerica-northeast2

# Optional: the Twilio number users text screenshots to (shown in the UI).
VITE_TWILIO_NUMBER=

# Optional: set to "true" to connect to local emulators during `npm run dev`.
VITE_USE_EMULATORS=false
